{
  "info": {
    "name": "Exora - Complete Notification System",
    "description": "Test all notification system endpoints - Courses, Student Registration, Payments, Unlock Requests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "student_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "course_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "dept_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "student_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "request_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@exora.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('admin_token', jsonData.token);",
                  "  console.log('✅ Admin token saved: ' + jsonData.token.substring(0, 20) + '...');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Student Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@email.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('student_token', jsonData.token);",
                  "  pm.environment.set('student_id', jsonData.user.id);",
                  "  console.log('✅ Student token saved');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register New Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newstudent{{$timestamp}}@email.com\",\n  \"password\": \"password123\",\n  \"fullName\": \"New Test Student\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Courses (Triggers Student Notifications)",
      "item": [
        {
          "name": "Get All Courses",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/courses",
              "host": ["{{base_url}}"],
              "path": ["courses"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  if (jsonData.length > 0) {",
                  "    pm.environment.set('course_id', jsonData[0].id);",
                  "    console.log('✅ Course ID saved: ' + jsonData[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Departments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/departments",
              "host": ["{{base_url}}"],
              "path": ["departments"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  if (jsonData.length > 0) {",
                  "    pm.environment.set('dept_id', jsonData[0].id);",
                  "    console.log('✅ Department ID saved: ' + jsonData[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Regular Course (→ Notifies ALL Students)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"JavaScript Fundamentals {{$timestamp}}\",\n  \"department_id\": \"{{dept_id}}\",\n  \"type\": \"regular\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/courses",
              "host": ["{{base_url}}"],
              "path": ["courses"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 🔔 VERIFY IN FRONTEND:",
                  "// 1. Open http://localhost:5173/student",
                  "// 2. Watch notification bell badge update in real-time",
                  "// 3. Go to /student/notifications",
                  "// 4. Should see new notification with 'course_added' type",
                  "console.log('🔔 NOTIFICATION CREATED FOR ALL STUDENTS');"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Mock Exam (→ Notifies ALL Students)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Mock Exam - Chapter 1 {{$timestamp}}\",\n  \"department_id\": \"{{dept_id}}\",\n  \"type\": \"mock\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/courses",
              "host": ["{{base_url}}"],
              "path": ["courses"]
            }
          }
        },
        {
          "name": "Create Exit Exam (→ Notifies ALL Students)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Final Exit Exam {{$timestamp}}\",\n  \"department_id\": \"{{dept_id}}\",\n  \"type\": \"exit\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/courses",
              "host": ["{{base_url}}"],
              "path": ["courses"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Notifications - Student View",
      "item": [
        {
          "name": "Get All Notifications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{student_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notifications",
              "host": ["{{base_url}}"],
              "path": ["notifications"]
            }
          }
        },
        {
          "name": "Get Unread Notifications Only",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{student_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notifications?unread=true",
              "host": ["{{base_url}}"],
              "path": ["notifications"],
              "query": [
                {
                  "key": "unread",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Mark Notification as Read",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{student_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/notifications/:notificationId/read",
              "host": ["{{base_url}}"],
              "path": ["notifications", ":notificationId", "read"],
              "variable": [
                {
                  "key": "notificationId",
                  "value": ""
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. Unlock Requests (Course Access)",
      "item": [
        {
          "name": "Student Requests Course Unlock (→ Notifies Admins)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{student_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": \"{{course_id}}\",\n  \"reason\": \"I need access to this course for my assignments\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/unlock-requests",
              "host": ["{{base_url}}"],
              "path": ["unlock-requests"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('request_id', jsonData.requestId);",
                  "  console.log('✅ Unlock request created. ID saved: ' + jsonData.requestId);",
                  "  console.log('🔔 NOTIFICATION SENT TO ALL ADMINS');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin Views All Unlock Requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/unlock-requests",
              "host": ["{{base_url}}"],
              "path": ["unlock-requests"]
            }
          }
        },
        {
          "name": "Admin Views Pending Unlock Requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/unlock-requests?status=pending",
              "host": ["{{base_url}}"],
              "path": ["unlock-requests"],
              "query": [
                {
                  "key": "status",
                  "value": "pending"
                }
              ]
            }
          }
        },
        {
          "name": "Student Views Own Unlock Requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{student_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/unlock-requests/student/{{student_id}}",
              "host": ["{{base_url}}"],
              "path": ["unlock-requests", "student", "{{student_id}}"]
            }
          }
        },
        {
          "name": "Admin Approves Unlock Request (→ Notifies Student)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/unlock-requests/{{request_id}}",
              "host": ["{{base_url}}"],
              "path": ["unlock-requests", "{{request_id}}"],
              "variable": [
                {
                  "key": "request_id",
                  "value": ""
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 🔔 VERIFY:",
                  "// 1. Student should get notification: 'Course Access Granted!'",
                  "// 2. Course should now be unlocked in student dashboard",
                  "// 3. Student can see course in /student/departments",
                  "console.log('✅ COURSE UNLOCKED FOR STUDENT');"
                ]
              }
            }
          ]
        },
        {
          "name": "Admin Rejects Unlock Request (→ Notifies Student)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"rejected\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/unlock-requests/{{request_id}}",
              "host": ["{{base_url}}"],
              "path": ["unlock-requests", "{{request_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 🔔 VERIFY:",
                  "// Student should get notification: 'Unlock Request Declined'",
                  "console.log('❌ UNLOCK REQUEST REJECTED');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "5. Payments (Triggers Admin Notification)",
      "item": [
        {
          "name": "Get All Payments (Admin Only)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/payments",
              "host": ["{{base_url}}"],
              "path": ["payments"]
            }
          }
        },
        {
          "name": "Get Pending Payments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/payments?status=pending",
              "host": ["{{base_url}}"],
              "path": ["payments"],
              "query": [
                {
                  "key": "status",
                  "value": "pending"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
